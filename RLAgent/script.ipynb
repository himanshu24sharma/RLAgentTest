    "import asyncio\n",
    "from RLAgent import RlagentEnv, RlagentAction\n",
    "\n",
    "with RlagentEnv(base_url=\"http://localhost:8000\").sync() as client:\n",
    "    result = client.reset()\n",
    "    result = client.step(RlagentAction(message=\"Hello\"))\n",
    "    print(result.observation)\n",
    "    \n"
   ]
